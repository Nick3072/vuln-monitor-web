{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "vuln-monitor-web",
	// HAE - HCLOUD 계정. OAuth 토큰이 다중 계정 접근 가능하여 비대화형 배포 시 계정 명시 필요.
	"account_id": "1fd0dfc495cd579134490965371cdb68",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-22",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "vuln-monitor-db",
			"database_id": "c7ef8a83-1bbd-4ddb-a811-fbfb262cb57b",
			"remote": true
		}
	],
	"ai": {
		"binding": "AI"
	},
	"vectorize": [
		{
			"binding": "VECTORIZE",
			"index_name": "vuln-monitor-solutions"
		}
	],
	"vars": {
		"ENVIRONMENT": "production"
	},
	// v3.5 Cron Trigger — login_attempts 보존기간(90일) 초과분 일일 정리(scheduled 핸들러).
	//   UTC 18:00 = KST 03:00 (운영 저부하 시간)
	"triggers": {
		"crons": ["0 18 * * *"]
	}
	// Secrets (set via `wrangler secret put <NAME>`):
	//   API_KEY                   - bearer token for /api/* (n8n / external automation, '_system_automation' 매핑)
	//   SESSION_SECRET            - HMAC 서명 키, 32+ 자 랜덤 문자열 (필수)
	//                                node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
	//   ADMIN_PASSWORD            - v2.7 호환용 / v3.0 부트스트랩 후 더 이상 사용 안 됨 — 폐기 권장
	//   N8N_REMATCH_WEBHOOK_URL   - e.g. https://n8n.example.com/webhook/vuln-rematch
	//   N8N_BACKFILL_WEBHOOK_URL  - e.g. https://n8n.example.com/webhook/vuln-full-backfill
	//   N8N_REMATCH_SECRET        - shared secret sent in x-rematch-secret header
	//   NVD_API_KEY               - optional, raises NVD rate limit (5→50 req/30s)
	//
	// v3.0 부트스트랩 (마이그레이션 적용 후 1회만):
	//   curl -X POST <worker>/admin/bootstrap \
	//     -H "Authorization: Bearer $API_KEY" \
	//     -H "Content-Type: application/json" \
	//     -d '{"username":"admin","password":"<강한비번>","display_name":"System Admin","groups":["system"]}'
	//
	// Vectorize index (one-time setup):
	//   wrangler vectorize create vuln-monitor-solutions --dimensions=768 --metric=cosine
}
